<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.Plugins.HelloWorld.ViewModels;assembly=UGSGit.Plugins.HelloWorld"
             x:Class="UGSGit.Plugins.HelloWorld.Views.HelloWorldToolbar"
             x:DataType="vm:HelloWorldToolbarViewModel">
    <TextBlock Text="{Binding Title}"
               FontWeight="Bold"
               VerticalAlignment="Center"
               Margin="16,0,0,0"
               Foreground="{DynamicResource Brush.FG2}" />
</UserControl>
