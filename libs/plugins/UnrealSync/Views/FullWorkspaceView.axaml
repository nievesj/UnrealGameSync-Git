<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.Plugins.UnrealSync.ViewModels;assembly=UGSGit.Plugins.UnrealSync"
             xmlns:c="clr-namespace:UGSGit.Plugins.UnrealSync.Converters;assembly=UGSGit.Plugins.UnrealSync"
             x:Class="UGSGit.Plugins.UnrealSync.Views.FullWorkspaceView"
             x:DataType="vm:FullWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <!-- Status / Action Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Popup}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <!-- Only Settings remains in toolbar — all workspace actions moved to graph context menu -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Classes="icon_button"
                            Width="32" Height="32"
                            ToolTip.Tip="Settings">
                        <Path Width="14" Height="14"
                              Data="{StaticResource Icons.Settings}"
                              Fill="{DynamicResource Brush.FG1}" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Project Info + Build Targets + Output Log -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*">
            <!-- Project Info (Phase 1b: engine version, build type, path) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Popup}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ProjectName}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Brush.FG1}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding EngineVersionText, StringFormat='Engine: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}" />
                        <TextBlock Text="{Binding EngineBuildType, StringFormat='({0})'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}" />
                        <TextBlock Text="{Binding EnginePathText, StringFormat='Path: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   ToolTip.Tip="{Binding EnginePathText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding ModuleCount, StringFormat='Modules: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}" />
                        <TextBlock Text="{Binding PluginCount, StringFormat='Plugins: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}" />
                    </StackPanel>
                    <!-- Editor build status + deploy (Phase 1b+: editor build + deploy) -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                        <TextBlock Text="{Binding EditorBuildStatusText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}" />
                        <Button Content="Deploy Editor"
                                Classes="flat"
                                Command="{Binding DeployEditorCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                FontSize="12"
                                Padding="8,2"
                                IsVisible="{Binding EditorBuildAvailable}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle Grid.Row="1" Fill="{DynamicResource Brush.Border2}" Height=".6" HorizontalAlignment="Stretch" Margin="0,8" />

            <!-- Build Targets -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.Contents}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Build Targets (steps the Build button will run)"
                               FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource Brush.Accent}" />
                    <ItemsControl ItemsSource="{Binding BuildTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Width="200"
                                               Foreground="{DynamicResource Brush.FG1}" />
                                    <TextBlock Text="{Binding Platform}"
                                               Foreground="{DynamicResource Brush.FG2}" />
                                    <TextBlock Text="{Binding Configuration}"
                                               Foreground="{DynamicResource Brush.FG2}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Rectangle Grid.Row="3" Fill="{DynamicResource Brush.Border2}" Height=".6" HorizontalAlignment="Stretch" Margin="0,8" />

            <!-- Output Log -->
            <Border Grid.Row="4"
                    Background="{DynamicResource Brush.Contents}"
                    BorderBrush="{DynamicResource Brush.Border2}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogOutput}"
                                          FontFamily="{DynamicResource Fonts.Monospace}"
                                          FontSize="12"
                                          Foreground="{DynamicResource Brush.FG1}"
                                          TextWrapping="Wrap">
                        <SelectableTextBlock.ContextFlyout>
                            <MenuFlyout>
                                <MenuItem Header="Copy"
                                           Command="{Binding $parent[SelectableTextBlock].Copy}"
                                           IsEnabled="{Binding $parent[SelectableTextBlock].CanCopy}"
                                           InputGesture="{x:Static TextBox.CopyGesture}">
                                    <MenuItem.Icon>
                                        <Path Width="11" Height="11" Data="{StaticResource Icons.Copy}" VerticalAlignment="Center" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Clear Log"
                                           Command="{Binding $parent[ItemsControl].((vm:FullWorkspaceViewModel)DataContext).ClearLogCommand}">
                                    <MenuItem.Icon>
                                        <Path Width="11" Height="11" Data="{StaticResource Icons.Clear}" VerticalAlignment="Center" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </SelectableTextBlock.ContextFlyout>
                    </SelectableTextBlock>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom bar (Phase 1b: publish status) -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.Popup}"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding PublishStatusText}"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG2}"
                           IsVisible="{Binding PublishStatusText, Converter={x:Static c:StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
