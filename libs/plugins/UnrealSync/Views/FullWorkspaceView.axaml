<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.Plugins.UnrealSync.ViewModels;assembly=UGSGit.Plugins.UnrealSync"
             xmlns:c="clr-namespace:UGSGit.Plugins.UnrealSync.Converters;assembly=UGSGit.Plugins.UnrealSync"
             x:Class="UGSGit.Plugins.UnrealSync.Views.FullWorkspaceView"
             x:DataType="vm:FullWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <!-- Status / Action Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.ContentBG}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <!-- Header row removed: redundant label -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Build"
                            Command="{Binding BuildCommand}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Content="Launch Editor"
                            Command="{Binding LaunchCommand}" />

                    <!-- Package button with flyout for profile selection (fixes M-1) -->
                    <Button Content="Package" IsEnabled="{Binding !IsBusy}">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="4" MinWidth="180">
                                    <TextBlock Text="Select profile:" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding PackageProfiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding DisplayName}"
                                                        Command="{Binding $parent[ItemsControl].((vm:FullWorkspaceViewModel)DataContext).PackageCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        Margin="0,2" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Publish"
                            Command="{Binding PublishCommand}"
                            IsEnabled="{Binding CanPublish}" />
                    <Button Content="⚙" Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Project Info + Build Targets + Output Log -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*">
            <!-- Project Info (Phase 1b: engine version, build type, path) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.ContentBG}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ProjectName}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Brush.FG1}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding EngineVersionText, StringFormat='Engine: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding EngineBuildType, StringFormat='({0})'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding EnginePathText, StringFormat='Path: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG4}"
                                   ToolTip.Tip="{Binding EnginePathText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding ModuleCount, StringFormat='Modules: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding PluginCount, StringFormat='Plugins: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                    </StackPanel>
                    <!-- Editor build status + deploy (Phase 1b+: editor build + deploy) -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                        <TextBlock Text="{Binding EditorBuildStatusText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <Button Content="Deploy Editor"
                                Command="{Binding DeployEditorCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                FontSize="12"
                                Padding="8,2"
                                IsVisible="{Binding EditorBuildAvailable}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Rectangle Grid.Row="1" Fill="{DynamicResource Brush.Border2}" Height=".6" HorizontalAlignment="Stretch" Margin="0,8" />

            <!-- Build Targets -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Brush.Contents}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Build Targets (steps the Build button will run)"
                               FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource Brush.Accent}" />
                    <ItemsControl ItemsSource="{Binding BuildTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Width="200"
                                               Foreground="{DynamicResource Brush.FG1}" />
                                    <TextBlock Text="{Binding Platform}"
                                               Foreground="{DynamicResource Brush.FG2}" />
                                    <TextBlock Text="{Binding Configuration}"
                                               Foreground="{DynamicResource Brush.FG2}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Rectangle Grid.Row="3" Fill="{DynamicResource Brush.Border2}" Height=".6" HorizontalAlignment="Stretch" Margin="0,8" />

            <!-- Output Log -->
            <Border Grid.Row="4"
                    Background="{DynamicResource Brush.Contents}"
                    BorderBrush="{DynamicResource Brush.Border2}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <ScrollViewer>
                    <TextBlock Text="{Binding LogOutput}"
                               FontFamily="{DynamicResource Fonts.Monospace}"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.FG1}"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom bar (Phase 1b: publish status) -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.ContentBG}"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding PublishStatusText}"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG3}"
                           IsVisible="{Binding PublishStatusText, Converter={x:Static c:StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
