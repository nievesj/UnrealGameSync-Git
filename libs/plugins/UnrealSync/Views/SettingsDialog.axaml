<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:UGSGit.Plugins.UnrealSync.Converters;assembly=UGSGit.Plugins.UnrealSync"
        xmlns:vm="clr-namespace:UGSGit.Plugins.UnrealSync.ViewModels;assembly=UGSGit.Plugins.UnrealSync"
        x:Class="UGSGit.Plugins.UnrealSync.Views.SettingsDialog"
        x:DataType="vm:SettingsDialogViewModel"
        Title="UnrealSync Settings"
        Width="520" Height="750"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">

            <!-- Engine section -->
            <Border Background="{DynamicResource Brush.Card}" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Engine" FontWeight="SemiBold" FontSize="14" />

                    <CheckBox Content="Auto-detect engine" IsChecked="{Binding AutoDetectEngine}" />

                    <TextBlock Text="Local engine path (saved to your local config, not shared with team):"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <TextBox Text="{Binding EnginePathOverride}"
                             IsEnabled="{Binding !AutoDetectEngine}"
                             Watermark="{Binding EnginePath}" />
                    <TextBlock Text="{Binding EnginePath, StringFormat='Auto-detected: {0}'}"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}"
                               IsVisible="{Binding AutoDetectEngine}" />
                    <TextBlock Text="{Binding EnginePathError}"
                               Foreground="Red" FontSize="11"
                               IsVisible="{Binding EnginePathError, Converter={x:Static c:StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

            <!-- Network Location section -->
            <Border Background="{DynamicResource Brush.Card}" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Network Location" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock Text="Base URL (UNC path or HTTP URL for archive &amp; publish):"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <TextBox Text="{Binding NetworkBaseUrl}"
                             Watermark="\\build-server\ue-binaries" />
                    <TextBlock Text="{Binding NetworkUrlError}"
                               Foreground="Red" FontSize="11"
                               IsVisible="{Binding NetworkUrlError, Converter={x:Static c:StringConverters.IsNotNullOrEmpty}}" />

                    <TextBlock Text="Channels (subdirectories under network base):"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Editor builds:" FontSize="11"
                                       Foreground="{DynamicResource Brush.FG3}" />
                            <TextBox Text="{Binding EditorChannel}"
                                     Watermark="Editor" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Game builds:" FontSize="11"
                                       Foreground="{DynamicResource Brush.FG3}" />
                            <TextBox Text="{Binding GameChannel}"
                                     Watermark="Game" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Binary name (zip prefix, defaults to .uproject name):"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <TextBox Text="{Binding BinaryName}"
                             Watermark="{Binding ProjectName}" />

                    <TextBlock Text="Badge colors (click swatch to pick):"
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Editor:" FontSize="11"
                                       Foreground="{DynamicResource Brush.FG3}" />
                            <Grid ColumnDefinitions="Auto,*">
                                <Button Grid.Column="0" Width="28" Height="28" Margin="0,0,8,0"
                                        CornerRadius="4"
                                        Background="{Binding EditorBadgeColor, Converter={x:Static c:HexToBrushConverter.Instance}, ConverterParameter=#00FF00}">
                                    <Button.Flyout>
                                        <Flyout>
                                            <ItemsControl ItemsSource="{Binding $parent[Window].((vm:SettingsDialogViewModel)DataContext).PresetColors}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel MaxWidth="180" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Width="24" Height="24" Margin="2"
                                                                Background="{Binding ., Converter={x:Static c:HexToBrushConverter.Instance}}"
                                                                Command="{Binding $parent[ItemsControl].((vm:SettingsDialogViewModel)DataContext).SetEditorColorCommand}"
                                                                CommandParameter="{Binding .}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                                <TextBox Grid.Column="1" Text="{Binding EditorBadgeColor}"
                                         Watermark="#00FF00" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Game:" FontSize="11"
                                       Foreground="{DynamicResource Brush.FG3}" />
                            <Grid ColumnDefinitions="Auto,*">
                                <Button Grid.Column="0" Width="28" Height="28" Margin="0,0,8,0"
                                        CornerRadius="4"
                                        Background="{Binding GameBadgeColor, Converter={x:Static c:HexToBrushConverter.Instance}, ConverterParameter=#FFA500}">
                                    <Button.Flyout>
                                        <Flyout>
                                            <ItemsControl ItemsSource="{Binding $parent[Window].((vm:SettingsDialogViewModel)DataContext).PresetColors}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel MaxWidth="180" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Width="24" Height="24" Margin="2"
                                                                Background="{Binding ., Converter={x:Static c:HexToBrushConverter.Instance}}"
                                                                Command="{Binding $parent[ItemsControl].((vm:SettingsDialogViewModel)DataContext).SetGameColorCommand}"
                                                                CommandParameter="{Binding .}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                                <TextBox Grid.Column="1" Text="{Binding GameBadgeColor}"
                                         Watermark="#FFA500" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Build Defaults section -->
            <Border Background="{DynamicResource Brush.Card}" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Build Defaults" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock Text="Output directory:" FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                    <TextBox Text="{Binding OutputDirectory}" Watermark="Saved/StagedBuilds" />
                </StackPanel>
            </Border>

            <!-- Publish Options section -->
            <Border Background="{DynamicResource Brush.Card}" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Publish Options" FontWeight="SemiBold" FontSize="14" />
                    <CheckBox Content="Atomic publish (write to temp, then rename)"
                              IsChecked="{Binding AtomicPublish}" />
                </StackPanel>
            </Border>

            <!-- Build Targets section -->
            <Border Background="{DynamicResource Brush.Card}" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Build Targets" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Steps the Build button runs. Choose UBT Build for compiling C++, UAT Build for packaging/cooking."
                               FontSize="11" Foreground="{DynamicResource Brush.FG3}" TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding BuildTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.ContentBG}" CornerRadius="4" Padding="8" Margin="0,2">
                                    <StackPanel Spacing="4">
                                        <!-- Row 0: Name, Mode, Type, Platform, Config, Delete -->
                                        <Grid ColumnDefinitions="*,*,*,*,*,Auto" Margin="0,0,0,2">
                                            <TextBox Grid.Column="0" Text="{Binding DisplayName}" Watermark="e.g. Editor Dev" Margin="0,0,4,0"
                                                     ToolTip.Tip="Friendly name shown in the workspace view." />
                                            <ComboBox Grid.Column="1" SelectedIndex="{Binding BuildMode, Converter={x:Static c:BuildModeConverter.Instance}, Mode=TwoWay}" Margin="0,0,4,0"
                                                       ToolTip.Tip="UBT Build = compile C++ only. UAT Build = cook/package/deploy. Custom = your own script.">
                                                <x:String>UBT Build</x:String>
                                                <x:String>UAT Build</x:String>
                                                <x:String>Custom Script</x:String>
                                            </ComboBox>
                                            <ComboBox Grid.Column="2" SelectedItem="{Binding BuildType}" Margin="0,0,4,0"
                                                       ToolTip.Tip="Target type. Game = {ProjectName}, Client = {ProjectName}Client, Editor = {ProjectName}Editor, Server = {ProjectName}Server">
                                                <x:String>Game</x:String>
                                                <x:String>Client</x:String>
                                                <x:String>Editor</x:String>
                                                <x:String>Server</x:String>
                                            </ComboBox>
                                            <ComboBox Grid.Column="3" SelectedItem="{Binding Platform}" Margin="0,0,4,0"
                                                       ToolTip.Tip="Target platform for the build.">
                                                <x:String>Win64</x:String>
                                                <x:String>Linux</x:String>
                                                <x:String>Mac</x:String>
                                                <x:String>Android</x:String>
                                                <x:String>IOS</x:String>
                                            </ComboBox>
                                            <ComboBox Grid.Column="4" SelectedItem="{Binding Configuration}" Margin="0,0,4,0"
                                                       ToolTip.Tip="Build configuration.">
                                                <x:String>Debug</x:String>
                                                <x:String>DebugGame</x:String>
                                                <x:String>Development</x:String>
                                                <x:String>Shipping</x:String>
                                                <x:String>Test</x:String>
                                            </ComboBox>
                                            <Button Grid.Column="5" Content="×"
                                                    Command="{Binding $parent[ItemsControl].((vm:SettingsDialogViewModel)DataContext).RemoveBuildTargetCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>

                                        <!-- Row 1: ScriptPath (full width) -->
                                        <TextBox Text="{Binding ScriptPath}" Watermark="{Binding BuildMode, Converter={x:Static c:BuildModeScriptPathHintConverter.Instance}}"
                                                 ToolTip.Tip="Path to a build script. Supports {EnginePath}, {ProjectName} variables. UBT: Build.bat, UAT: RunUAT.bat." />

                                        <!-- Row 2: UAT Command dropdown (visible only when BuildMode=Uat) -->
                                        <ComboBox IsVisible="{Binding ShowUatCommand}"
                                                  SelectedItem="{Binding UatCommand}"
                                                  ToolTip.Tip="Select which UAT command to run. Each preset pre-populates the Arguments field.">
                                            <x:String>BuildCookRun</x:String>
                                            <x:String>BuildEditor</x:String>
                                            <x:String>BuildGame</x:String>
                                            <x:String>BuildServer</x:String>
                                            <x:String>BuildGraph</x:String>
                                            <x:String>Custom</x:String>
                                        </ComboBox>

                                        <!-- Row 3: Arguments (full width) -->
                                        <TextBox Text="{Binding Arguments}" Watermark="Command-line arguments for the build script"
                                                 ToolTip.Tip="Arguments passed to the script. Supports {Target}, {UbtTarget}, {Platform}, {Configuration}, {ProjectName}, {ProjectPath}, {EnginePath}, {ArchiveDir} variables." />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Variables reference -->
                    <Border Background="{DynamicResource Brush.ContentBG}" CornerRadius="4" Padding="8">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Available variables" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource Brush.FG2}" />
                            <ItemsControl ItemsSource="{Binding AvailableVariables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontFamily="Cascadia Code, Consolas, monospace" FontSize="11" Foreground="{DynamicResource Brush.Accent}" />
                                            <TextBlock Text="—" FontSize="11" Foreground="{DynamicResource Brush.FG4}" />
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource Brush.FG3}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Button Content="+ Add Target" Command="{Binding AddBuildTargetCommand}" />
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Content="Save &amp; Apply" Command="{Binding SaveCommand}"
                        Classes="accent" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>