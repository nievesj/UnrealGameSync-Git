<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.Plugins.UnrealSync.ViewModels;assembly=UGSGit.Plugins.UnrealSync"
             xmlns:c="clr-namespace:UGSGit.Plugins.UnrealSync.Converters;assembly=UGSGit.Plugins.UnrealSync"
             x:Class="UGSGit.Plugins.UnrealSync.Views.SelectUProjectView"
             x:DataType="vm:SelectUProjectViewModel">

    <Border Background="{DynamicResource Brush.Background}"
            CornerRadius="8"
            Margin="16"
            Padding="32">
        <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="{DynamicResource Brush.FG1}" />

            <!-- List of discovered projects (if any) -->
            <ListBox ItemsSource="{Binding DiscoveredProjects}"
                     SelectedItem="{Binding SelectedProject}"
                     IsVisible="{Binding HasDiscoveredProjects}"
                     MaxHeight="200"
                     BorderBrush="{DynamicResource Brush.Border}"
                     BorderThickness="1"
                     CornerRadius="3">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas, monospace" Margin="4,2" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <Button Content="Use Selected"
                        IsVisible="{Binding HasDiscoveredProjects}"
                        Command="{Binding UseSelectedCommand}"
                        IsEnabled="{Binding SelectedProject, Converter={x:Static c:ObjectConverters.IsNotNull}}"
                        Width="120" Height="32" />
                <Button Content="Browse..."
                        Command="{Binding BrowseCommand}"
                        Width="120" Height="32" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
