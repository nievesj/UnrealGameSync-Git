<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.Plugins.UnrealSync.ViewModels;assembly=UGSGit.Plugins.UnrealSync"
             x:Class="UGSGit.Plugins.UnrealSync.Views.StatusPanelView"
             x:DataType="vm:StatusPanelViewModel">
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0,0,0">
        <TextBlock Text="{Binding BranchText}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.FG1}" />
    </StackPanel>
</UserControl>
