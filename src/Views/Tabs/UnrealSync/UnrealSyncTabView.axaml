<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UGSGit.ViewModels.Tabs.UnrealSync"
             xmlns:v="clr-namespace:UGSGit.Views.Tabs.UnrealSync"
             x:Class="UGSGit.Views.Tabs.UnrealSync.UnrealSyncTabView"
             x:DataType="vm:UnrealSyncTabViewModel">
    <ContentControl Content="{Binding CurrentBody}">
        <ContentControl.DataTemplates>
            <DataTemplate DataType="vm:SelectUProjectViewModel">
                <v:SelectUProjectView />
            </DataTemplate>
            <DataTemplate DataType="vm:EngineNotFoundViewModel">
                <v:EngineNotFoundView />
            </DataTemplate>
            <DataTemplate DataType="vm:FullWorkspaceViewModel">
                <v:FullWorkspaceView />
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</UserControl>
