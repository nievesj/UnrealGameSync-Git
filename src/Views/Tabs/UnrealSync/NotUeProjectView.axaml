<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SourceGit.ViewModels.Tabs.UnrealSync"
             x:Class="SourceGit.Views.Tabs.UnrealSync.NotUeProjectView"
             x:DataType="vm:NotUeProjectViewModel">
    <Border Background="{DynamicResource Brush.Background}"
            CornerRadius="8"
            Margin="16"
            Padding="32">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="UE"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Brush.FG3}" />
            <TextBlock Text="{Binding Message}"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Brush.FG1}" />
            <TextBlock Text="{Binding Description}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="500"
                       Foreground="{DynamicResource Brush.FG3}" />
        </StackPanel>
    </Border>
</UserControl>
