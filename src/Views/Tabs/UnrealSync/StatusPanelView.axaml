<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SourceGit.ViewModels.Tabs.UnrealSync"
             x:Class="SourceGit.Views.Tabs.UnrealSync.StatusPanelView"
             x:DataType="vm:StatusPanelViewModel">
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="{Binding BranchText, StringFormat='● {0}'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.FG1}" />
        <TextBlock Text="{Binding CommitText}"
                   FontSize="12"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.FG3}" />
    </StackPanel>
</UserControl>
