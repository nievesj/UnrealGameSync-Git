<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SourceGit.ViewModels.Tabs.UnrealSync"
             x:Class="SourceGit.Views.Tabs.UnrealSync.FullWorkspaceView"
             x:DataType="vm:FullWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <!-- Status / Action Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.ContentBG}"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding BranchText}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.FG1}" />
                    <TextBlock Text="{Binding CommitText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.FG3}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Sync Now"
                            Command="{Binding SyncCommand}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Content="Build"
                            Command="{Binding BuildCommand}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Content="Launch Editor"
                            Command="{Binding LaunchCommand}" />

                    <!-- Package button with flyout for profile selection (fixes M-1) -->
                    <Button Content="Package" IsEnabled="{Binding !IsBusy}">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="4" MinWidth="180">
                                    <TextBlock Text="Select profile:" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding PackageProfiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding DisplayName}"
                                                        Command="{Binding $parent[ItemsControl].((vm:FullWorkspaceViewModel)DataContext).PackageCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        Margin="0,2" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="Publish"
                            Command="{Binding PublishCommand}"
                            IsEnabled="{Binding CanPublish}" />
                    <Button Content="⚙" Click="OpenSettings" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Project Info + Output Log (split) -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <!-- Project Info (Phase 1b: engine version, build type, path) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.ContentBG}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ProjectName}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Brush.FG1}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding EngineVersionText, StringFormat='Engine: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding EngineBuildType, StringFormat='({0})'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding EnginePathText, StringFormat='Path: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG4}"
                                   ToolTip.Tip="{Binding EnginePathText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="{Binding ModuleCount, StringFormat='Modules: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                        <TextBlock Text="{Binding PluginCount, StringFormat='Plugins: {0}'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG3}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Build Targets + Output Log -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource Brush.ContentBG}"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,8">
                    <ItemsControl ItemsSource="{Binding BuildTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Width="200"
                                               Foreground="{DynamicResource Brush.FG1}" />
                                    <TextBlock Text="{Binding Platform}"
                                               Foreground="{DynamicResource Brush.FG3}" />
                                    <TextBlock Text="{Binding Configuration}"
                                               Foreground="{DynamicResource Brush.FG3}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Output Log -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Brush.ContentBG}"
                        CornerRadius="6"
                        Padding="12">
                    <ScrollViewer>
                        <TextBlock Text="{Binding LogOutput}"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom bar (Phase 1b: publish status) -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.ContentBG}"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="UnrealSync — Phase 1b"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG4}" />
                <TextBlock Text="{Binding PublishStatusText}"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG3}"
                           IsVisible="{Binding PublishStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>