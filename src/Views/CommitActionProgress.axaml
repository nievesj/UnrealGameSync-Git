<v:ChromelessWindow xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:v="using:UGSGit.Views"
                    xmlns:vm="using:UGSGit.ViewModels"
                    mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="360"
                    x:Class="UGSGit.Views.CommitActionProgress"
                    x:DataType="vm:CommitActionProgress"
                    x:Name="ThisControl"
                    Title="{Binding WindowTitle}"
                    Width="520" Height="360"
                    CanResize="True"
                    WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Title bar -->
    <Grid Grid.Row="0" Height="28" IsVisible="{Binding !#ThisControl.UseSystemWindowFrame}">
      <Border Background="{DynamicResource Brush.TitleBar}"
              BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border0}"
              PointerPressed="BeginMoveWindow"/>
      <Path Name="TitleBarIcon" Width="14" Height="14"
            Margin="10,0,0,0" HorizontalAlignment="Left"
            IsVisible="{OnPlatform True, macOS=False}"/>
      <TextBlock Classes="bold"
                 Text="{Binding WindowTitle}"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="False"/>
      <v:CaptionButtons HorizontalAlignment="Right"
                        IsCloseButtonOnly="True"
                        IsVisible="{OnPlatform True, macOS=False}"/>
    </Grid>

    <!-- Log output (scrollable, monospace) -->
    <Border Grid.Row="1" Margin="8" BorderThickness="1"
            BorderBrush="{DynamicResource Brush.Border2}"
            Background="{DynamicResource Brush.Contents}">
      <ScrollViewer Name="LogScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <TextBlock Text="{Binding LogText}"
                   FontFamily="Consolas,monospace"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="4"
                   Foreground="{DynamicResource Brush.FG1}"/>
      </ScrollViewer>
    </Border>

    <!-- Buttons + error message -->
    <Grid Grid.Row="2" Margin="8,0,8,8" ColumnDefinitions="*,Auto">
      <!-- Error message (left-aligned) -->
      <TextBlock Grid.Column="0"
                 Text="{Binding ErrorMessage}"
                 Foreground="{DynamicResource Brush.Bad}"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"
                 IsVisible="{Binding IsError}"/>

      <!-- Cancel (visible while running) -->
      <Button Grid.Column="1"
              Classes="flat"
              Height="28" Margin="8,0" Padding="12,0"
              Content="{DynamicResource Text.CommitAction.Cancel}"
              IsVisible="{Binding IsRunning}"
              Click="OnCancelClicked"/>

      <!-- Done (visible when not running) -->
      <Button Grid.Column="1"
              Classes="flat primary"
              Height="28" Margin="8,0" Padding="12,0"
              Content="{DynamicResource Text.CommitAction.Done}"
              IsVisible="{Binding !IsRunning}"
              Click="OnDoneClicked"/>
    </Grid>
  </Grid>
</v:ChromelessWindow>
