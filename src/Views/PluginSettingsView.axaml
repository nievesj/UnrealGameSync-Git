<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UGSGit.ViewModels"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="400"
             x:Class="UGSGit.Views.PluginSettingsView"
             x:DataType="vm:PluginSettingsViewModel">
  <Grid RowDefinitions="*,Auto" Margin="8">
    <!-- Plugin List -->
    <ScrollViewer Grid.Row="0">
      <ItemsControl ItemsSource="{Binding Plugins}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PluginRow">
            <Border Margin="0,0,0,8"
                    Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource Brush.Contents}"
                    BorderBrush="{DynamicResource Brush.Border2}"
                    BorderThickness="1">
              <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">

                <!-- Row 0: Checkbox + Name + Version + Author -->
                <CheckBox Grid.Row="0" Grid.Column="0"
                          IsChecked="{Binding IsGloballyEnabled}"
                          IsVisible="{Binding IsLoaded}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding DisplayName}"
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="0" Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                  <TextBlock Text="v" FontSize="11" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                  <TextBlock Text=" by " FontSize="11" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Author}" FontSize="11" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 1: Description -->
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                           Text="{Binding Description}"
                           FontSize="12"
                           Foreground="{DynamicResource Brush.FG2}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>

                <!-- Row 2: Default mode / Error -->
                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,4,0,0">
                  <Border IsVisible="{Binding IsLoaded}"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="{DynamicResource Brush.Background}">
                    <TextBlock FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                               Text="{Binding DefaultModeText}"/>
                  </Border>

                  <!-- Error message -->
                  <Border IsVisible="{Binding HasError}"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="#33FF0000">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="11"
                               Foreground="#FFFF6666"
                               TextWrapping="Wrap"/>
                  </Border>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Open Plugins Folder Button -->
    <Button Grid.Row="1"
            Classes="flat"
            HorizontalAlignment="Left"
            Margin="0,8,0,0"
            Click="OnOpenPluginsFolder">
      <StackPanel Orientation="Horizontal">
        <Path Width="14" Height="14" Data="{StaticResource Icons.Folder}" Fill="{DynamicResource Brush.FG2}"/>
        <TextBlock Margin="6,0,0,0" Text="Open Plugins Folder"/>
      </StackPanel>
    </Button>
  </Grid>
</UserControl>